<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MapIslandEditor.App"
             RequestedThemeVariant="Dark">
  <Application.Styles>
    <FluentTheme />
  </Application.Styles>
  
  <Application.Resources>
    <Color x:Key="PrimaryAccent">#FFFFB30F</Color>
    <Color x:Key="DarkBg">#FF2A2A2A</Color>
    <Color x:Key="MediumBg">#FF373737</Color>
    <Color x:Key="LightBg">#FF4A4A4A</Color>
    <Color x:Key="TextPrimary">#FFF6F6F6</Color>
    <Color x:Key="TextSecondary">#FFEAEAEA</Color>
  </Application.Resources>
</Application>
